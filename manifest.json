{
  "manifest_version": 3,
  "name": "Auto Form Filler (МИС БАРС)",
  "version": "1.3",
  "description": "Автоматическое назначение анализов в МИС БАРС с выбором профилей",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "./images/icon16.png",
      "48": "./images/icon48.png",
      "128": "./images/icon128.png"
    }
  }
}